<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Chi tiết bài viết</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container mt-5">
        <div class="card shadow-sm border-0">
            <div class="card-body p-5">
                <h1 class="card-title text-primary fw-bold mb-4"><%= post.title %></h1>
                <p class="card-text text-dark" style="white-space: pre-line; font-size: 1.1rem; line-height: 1.8;">
                    <%= post.body %>
                </p>
                <hr class="mt-5">
                <a href="/" class="btn btn-outline-secondary">&larr; Về trang chủ</a>
            </div>
        </div>
    </div>
</body>
</html>