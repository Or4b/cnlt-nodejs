<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Sửa bài viết</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <h1>Sửa bài viết</h1>
    
    <form action="/blogposts/update/<%= post._id %>" method="POST">
        <p>
            Tiêu đề:<br>
            <input type="text" name="title" value="<%= post.title %>" required>
        </p>
        <p>
            Nội dung:<br>
            <textarea name="body" rows="5" cols="40" required><%= post.body %></textarea>
        </p>
        <button type="submit">Cập nhật</button>
    </form>
    
    <br>
    <a href="/">Về trang chủ</a>
</body>
</html>